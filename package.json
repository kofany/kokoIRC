{
  "name": "kokoirc",
  "version": "0.2.4",
  "description": "Modern terminal IRC client with inline image preview, SASL, scripting, encrypted logging, and theming — built with OpenTUI, React, and Bun",
  "license": "MIT",
  "author": {
    "name": "kofany",
    "url": "https://github.com/kofany"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kofany/kokoIRC.git"
  },
  "homepage": "https://kofany.github.io/kokoIRC/",
  "bugs": {
    "url": "https://github.com/kofany/kokoIRC/issues"
  },
  "keywords": [
    "irc",
    "irc-client",
    "terminal",
    "tui",
    "cli",
    "client",
    "chat",
    "opentui",
    "react",
    "bun",
    "sasl",
    "sixel",
    "image-preview",
    "theming",
    "scripting",
    "sqlite",
    "encrypted-logging"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "os": [
    "darwin",
    "linux"
  ],
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "kokoirc": "src/index.tsx"
  },
  "files": [
    "src",
    "themes",
    "docs/commands",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "test": "bun test",
    "build": "bun build --compile src/index.tsx --outfile openirc",
    "docs:build": "bun run docs/build.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/sharp": "^0.32.0",
    "typescript": "^5.9.3"
  },
  "imports": {
    "@/*": "./src/*"
  },
  "dependencies": {
    "@opentui/core": "^0.1.83",
    "@opentui/react": "^0.1.83",
    "kofany-irc-framework": "^4.14.1",
    "react": "^19.2.4",
    "sharp": "^0.34.5",
    "sixel": "^0.16.0",
    "smol-toml": "^1.6.0",
    "zustand": "^5.0.11"
  }
}
