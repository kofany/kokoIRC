{
  "name": "kokoirc-client",
  "version": "0.1.2",
  "description": "Terminal IRC client built with OpenTUI and React",
  "module": "src/index.tsx",
  "type": "module",
  "bin": {
    "kokoirc": "src/index.tsx"
  },
  "files": [
    "src",
    "themes",
    "docs/commands",
    "tsconfig.json"
  ],
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun --watch run src/index.tsx",
    "test": "bun test",
    "build": "bun build --compile src/index.tsx --outfile openirc"
  },
  "devDependencies": {
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/sharp": "^0.32.0",
    "typescript": "^5.9.3"
  },
  "imports": {
    "@/*": "./src/*"
  },
  "dependencies": {
    "@opentui/core": "^0.1.83",
    "@opentui/react": "^0.1.83",
    "kofany-irc-framework": "^4.14.1",
    "react": "^19.2.4",
    "sharp": "^0.34.5",
    "sixel": "^0.16.0",
    "smol-toml": "^1.6.0",
    "zustand": "^5.0.11"
  }
}
